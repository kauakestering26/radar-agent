# Radar Agent POC — exemplo de variáveis de ambiente
#
# Copie este arquivo para `.env` e ajuste os valores.
# O `.env` nunca deve ser commitado (já está no .gitignore).

# ── Agent ────────────────────────────────────────────────────────────────────

# URL do Control Plane (WebSocket). Em produção: wss://radar.seudominio.com
CONTROL_PLANE_URL=ws://control-plane:8000

# Identificador único deste agent. Use algo estável por máquina/cliente.
AGENT_ID=agent-cliente-1

# Intervalo do heartbeat em segundos
HEARTBEAT_INTERVAL=10

# Token compartilhado para autenticar o agent no Control Plane
# (a implementação de auth entra num próximo PR — variável reservada aqui)
# AGENT_TOKEN=change-me

# ── Conectores do Agent ──────────────────────────────────────────────────────
# Credenciais dos sistemas do cliente. Vivem SÓ aqui, no agent, e NUNCA
# trafegam via WebSocket — o control plane dispara scans sem ver esses valores.

# PostgreSQL — DSN completa (ganha precedência sobre os campos discretos)
POSTGRES_DSN=postgresql://radar:radar@postgres-target:5432/radar_test
# Ou em campos separados (se não quiser usar DSN):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=radar_test
# POSTGRES_USER=radar
# POSTGRES_PASSWORD=radar

# ── Control Plane ────────────────────────────────────────────────────────────

# (reservado para quando houver persistência)
# DATABASE_URL=postgresql+asyncpg://radar:radar@db:5432/radar_agent
